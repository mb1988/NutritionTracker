# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public&sslmode=require"

# GitHub OAuth app credentials
GITHUB_ID="your-github-oauth-app-id"
GITHUB_CLIENT_SECRET="your-github-oauth-app-secret"

# Restrict sign-in to a single GitHub username
ALLOWED_GITHUB_USERNAME="your-github-username"

# NextAuth runtime configuration
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

